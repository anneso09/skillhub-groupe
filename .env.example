# ─────────────────────────────────────────────────────────────────
# .env.example
# Copier ce fichier en .env et remplir les valeurs
#   cp .env.example .env  (Linux/Mac)
#   copy .env.example .env (Windows)
# ─────────────────────────────────────────────────────────────────

# ── MySQL ─────────────────────────────────────────────────────────
DB_DATABASE=skillhub_db
DB_USERNAME=skillhub_user
DB_PASSWORD=change_me_password

# ── MongoDB ───────────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017
MONGODB_URI=mongodb://mongodb:27017
MONGO_DB=skillhub_logs
MONGODB_DATABASE=skillhub_logs

# ── Spring Boot ───────────────────────────────────────────────────
# Doit faire exactement 32 caractères pour AES-256
APP_MASTER_KEY=change_me_32_chars_master_key_!!
# Clé longue et aléatoire pour signer les tokens JWT
JWT_SECRET=change_me_very_long_jwt_secret_key_2026

# ── Laravel ───────────────────────────────────────────────────────
# Générer avec : php artisan key:generate
APP_KEY=base64:change_me_laravel_app_key